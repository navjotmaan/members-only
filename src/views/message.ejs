<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>ConvoHub</title>
</head>
<body>
    <form action="/message/add" method="post" class="flex flex-col gap-8 mt-20 m-auto max-w-120">
        <h2 class="m-auto font-semibold text-2xl mb-10">Write your message</h2>

        <%- include('partials/errors.ejs') %>

        <div class="flex items-center">
            <label for="title" class="w-30 font-medium">Title: </label>
            <input name="title" id="title" class="border rounded flex-1 p-1 font-medium" 
                value="<%= locals.oldInput ? oldInput.title : '' %>" />
        </div>
        
        <div class="flex">
            <label for="message" class="w-30 font-medium">Message: </label>
            <textarea name="message" id="message" rows="5" class="border rounded flex-1 p-1" 
                value="<%= locals.oldInput ? oldInput.message : '' %>" ></textarea>
        </div>

        <button type="submit"class="bg-purple-600 w-40 p-1 rounded text-white font-semibold cursor-pointer m-auto">Post</button>
    </form>
</body>
</html>