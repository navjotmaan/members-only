<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/style.css">
    <title>ConvoHub</title>
</head>
<body>
    <header class="flex justify-between py-5 px-20">
        <h1 class="text-2xl font-bold">Convo<span class="text-purple-500">Hub</span></h1>
        <div class="flex gap-5">
            <a href="/login" class="text-[#ced4da] font-semibold px-3">Log in</a>
            <a href="/sign-up" class="bg-white text-black rounded py-1 font-semibold px-3">Sign up</a>
        </div>
    </header>

    <main class="mt-40 px-15">
        <p class="text-7xl max-w-[70%] font-semibold mb-8">Connect with people in real time</p>
        <p class="text-xl text-[#ced4da] max-w-[55%] mb-10">Your go to place to build a community that shares your interests. Share what’s on your mind and read what the world is saying.</p>
        <a href="/sign-up" class="bg-purple-500 text-white font-bold rounded text-lg py-2 px-4">Join Convo</a>
    </main>
</body>
</html>