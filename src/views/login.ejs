<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <link rel="stylesheet" href="/css/style.css">
  <title>ConvoHub</title>
</head>
<body>

  <form action="/login" method="POST" class="flex flex-col gap-8 mt-20 m-auto font-medium max-w-120">
    <h2 class="m-auto font-bold text-[#b34467] text-2xl mb-10">Log In to your account</h2>

    <%- include('partials/errors.ejs') %>

    <div class="flex items-center">
      <label for="email" class="w-30">Email: </label>
      <input id="email" name="email" type="email" 
        class="border rounded flex-1 p-1" 
        value="<%= locals.oldInput ? oldInput.email : '' %>"
      />
    </div>

    <div class="flex items-center">
      <label for="password" class="w-30">Password: </label>
      <input id="password" name="password" 
        type="password" 
        class="border rounded flex-1 p-1" 
      />
    </div>

    <button type="submit" class="bg-[#000000] w-40 p-1 rounded text-white font-semibold cursor-pointer m-auto">
      Log In
    </button>
  </form>
  
</body>
</html>
